<Window x:Class="CodexAccountSwitcher.Views.EditAccountMetadataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑额度记录"
        Icon="../Assets/CodexAccountSwitcher.ico"
        Width="420"
        Height="330"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        ShowInTaskbar="False">
    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
                <RowDefinition Height="64" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="20,0,12,0"
                  Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Text="编辑额度记录" />
                <Button x:Name="HeaderCloseButton"
                        Grid.Column="1"
                        Width="36"
                        Click="Cancel_Click"
                        Style="{StaticResource ActionButtonStyle}"
                        ToolTip="关闭"
                        AutomationProperties.Name="关闭">
                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="14" Text="&#xE8BB;" />
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Margin="20,14,20,8">
                <TextBlock FontWeight="SemiBold" Text="单次周/月额度（美元）" />
                <TextBlock Margin="0,3,0,7"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11"
                           Text="只记录一次基础额度，不乘赠送重置次数；不知道可留空。" />
                <TextBox x:Name="PeriodQuotaTextBox"
                         Height="32"
                         Padding="8,5"
                         VerticalContentAlignment="Center" />

                <TextBlock Margin="0,15,0,0"
                           FontWeight="SemiBold"
                           Text="累计已使用重置次数（本机记录）" />
                <TextBox x:Name="UsedResetCountTextBox"
                         Height="32"
                         Margin="0,7,0,0"
                         Padding="8,5"
                         VerticalContentAlignment="Center" />

                <TextBlock x:Name="ValidationText"
                           Margin="0,10,0,0"
                           Foreground="#B42318"
                           TextWrapping="Wrap" />
            </StackPanel>

            <Border Grid.Row="2"
                    Padding="20,14"
                    Background="{StaticResource WindowBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Width="82"
                            Margin="0,0,8,0"
                            Click="Cancel_Click"
                            Content="取消"
                            IsCancel="True"
                            Style="{StaticResource ActionButtonStyle}" />
                    <Button Width="82"
                            Click="Save_Click"
                            Content="保存"
                            IsDefault="True"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
