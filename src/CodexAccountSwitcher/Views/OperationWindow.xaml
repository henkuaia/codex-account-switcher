<Window x:Class="CodexAccountSwitcher.Views.OperationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Account operation"
        Width="560"
        Height="430"
        MinWidth="480"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        ShowInTaskbar="False"
        Closing="Window_Closing">
    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="58" />
                <RowDefinition Height="*" />
                <RowDefinition Height="66" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="20,0,14,0"
                  Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="HeadingText"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="PhaseText"
                               Margin="0,2,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
                <Button x:Name="HeaderCloseButton"
                        Grid.Column="1"
                        Width="36"
                        Click="Close_Click"
                        Style="{StaticResource ActionButtonStyle}"
                        ToolTip="Close"
                        Visibility="Collapsed">
                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="14" Text="&#xE8BB;" />
                </Button>
            </Grid>

            <Border Grid.Row="1"
                    Margin="20,8,20,16"
                    Background="#202629"
                    CornerRadius="6">
                <TextBox x:Name="OutputTextBox"
                         Padding="14,12"
                         Background="Transparent"
                         BorderThickness="0"
                         FontFamily="Cascadia Mono, Consolas"
                         FontSize="12"
                         Foreground="#F3F6F7"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
            </Border>

            <Border Grid.Row="2"
                    Padding="20,14"
                    Background="{StaticResource WindowBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <Button x:Name="CloseButton"
                        Width="88"
                        HorizontalAlignment="Right"
                        Click="Close_Click"
                        Content="Close"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Visibility="Collapsed" />
            </Border>
        </Grid>
    </Border>
</Window>
